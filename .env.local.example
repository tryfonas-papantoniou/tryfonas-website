# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real keys.

# Anthropic API — answers are generated by Claude Haiku 4.5
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — text embeddings (voyage-3, 1024 dims)
VOYAGE_API_KEY=pa-...

# Pinecone — optional vector store backend.
# Only needed when querying `/api/rag?backend=pinecone`. The default
# backend is an in-memory index shipped with the build.
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=tryfonas-rag-demo
